# PostgreSQL pripojenie (Neon/Supabase/lokálny Docker)
DATABASE_URL=postgres://user:password@localhost:5432/rezervacie

# Port API servera
PORT=3001

# Dĺžka dočasného zámku termínu počas platby (minúty)
HOLD_TTL_MINUTES=15

# keepi ERP (Fáza 3) – prázdny KEEPI_API_URL = adaptér vypnutý, eventy čakajú v outboxe
KEEPI_API_URL=https://keepi.example.com/api
KEEPI_API_KEY=
KEEPI_WEBHOOK_SECRET=

# Service manager – HMAC podpis webhookov o zmene dostupnosti personálu
SERVICE_MANAGER_WEBHOOK_SECRET=

# Zákaznícky web (Fáza 4) – povolený CORS origin
WEB_ORIGIN=http://localhost:3000

# Admin API – zdieľaný token (Authorization: Bearer <token>).
# Prázdne alebo nenastavené = admin API vracia 503 (fail-closed, NIE otvorené).
# Vygeneruj napr.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=
