{
  "name": "rezervacny-system",
  "version": "0.1.0",
  "description": "Rezervačný systém pre ubytovanie + služby (Express + TypeScript + PostgreSQL)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "tsx --test tests/*.test.ts",
    "db:init": "node scripts/init-db.mjs",
    "db:init:psql": "psql \"$DATABASE_URL\" -f db/schema.sql"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
